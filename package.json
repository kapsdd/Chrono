{
  "name": "chrono",
  "version": "2.1.0",
  "private": true,
  "description": "CHRONO — premium dark-green glassmorphism task manager (Phase 1: web core)",
  "author": "CHRONO",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "preview": "npx --yes serve out",
    "electron": "electron .",
    "app:dev": "next build && electron .",
    "dist": "next build && electron-builder",
    "package:win": "next build && electron-packager . CHRONO --platform=win32 --arch=x64 --out=release --overwrite --asar --prune=false --ignore=\"/node_modules\" --ignore=\"/(src|prisma|shablon|knopki|release|\\.next|\\.claude)\" --ignore=\"\\.(ts|tsx|tsbuildinfo|log)$\""
  },
  "dependencies": {
    "@fontsource/inter": "^5.1.1",
    "@fontsource/jetbrains-mono": "^5.1.1",
    "@supabase/supabase-js": "^2.108.2",
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "github": "^14.0.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "com.chrono.app",
    "productName": "CHRONO",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "okno/icon.png",
      "package.json",
      "!**/node_modules/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "okno/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CHRONO",
      "installerIcon": "okno/icon.ico",
      "uninstallerIcon": "okno/icon.ico",
      "runAfterFinish": true,
      "artifactName": "CHRONO-Setup-${version}.${ext}"
    }
  }
}
